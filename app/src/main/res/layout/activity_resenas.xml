<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloResenas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reseñas del club"
            android:textColor="@color/azul_principal"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvMediaResenas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="⭐ Sin reseñas todavía"
            android:textColor="@color/negro"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAvisoResenas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_club"
            android:padding="14dp"
            android:text="Solo puedes reseñar si ya has usado una pista."
            android:textColor="@color/gris"
            android:textSize="15sp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Tu puntuación"
            android:textColor="@color/negro"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spinnerEstrellas"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"/>

        <EditText
            android:id="@+id/etComentario"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_club"
            android:gravity="top"
            android:hint="Escribe tu reseña"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/negro"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnGuardarResena"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/azul_principal"
            android:text="Guardar reseña"
            android:textColor="@color/blanco"/>

        <Button
            android:id="@+id/btnVolverResenas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/azul_principal"
            android:text="Volver"/>

        <TextView
            android:id="@+id/tvSinResenas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Todavía no hay reseñas para este club."
            android:textColor="@color/gris"
            android:textSize="16sp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerResenas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</ScrollView>