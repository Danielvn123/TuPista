<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardClub"
    android:layout_width="match_parent"
    android:layout_height="175dp"
    android:layout_marginBottom="18dp"
    android:background="@drawable/bg_card_club"
    android:clickable="true"
    android:elevation="6dp"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/imgClub"
        android:layout_width="135dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_imagen_redonda"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:src="@drawable/pista_padel" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="16dp">

        <TextView
            android:id="@+id/tvNombreClub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Club"
            android:textColor="@color/negro"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDireccionClub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:text="Dirección"
            android:textColor="@color/gris_oscuro"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTelefonoClub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:text="Teléfono"
            android:textColor="@color/gris_oscuro"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTotalPistas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:text="0 pistas"
            android:textColor="@color/gris_oscuro"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnVerResenas"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="6dp"
            android:backgroundTint="@color/azul_principal"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="Reseñas"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>