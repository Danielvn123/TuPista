<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    android:background="#FFFFFF"
    android:elevation="6dp"
    android:orientation="vertical"
    android:padding="18dp">

    <!-- ESTADO -->

    <TextView
        android:id="@+id/tvEstadoReservaUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="Próximo"
        android:textStyle="bold" />

    <!-- CLUB -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/localizacion" />

        <TextView
            android:id="@+id/tvClubUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Club"
            android:textColor="@color/negro"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- FECHA -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/reservas" />

        <TextView
            android:id="@+id/tvFechaUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- HORA -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/reloj" />

        <TextView
            android:id="@+id/tvHoraUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hora"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- PISTA -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/raqueta_tenis" />

        <TextView
            android:id="@+id/tvPistaUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pista"
            android:textSize="15sp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnCancelarReservaUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/rojo"
        android:text="Cancelar reserva"
        android:textAllCaps="false"
        android:textColor="@color/blanco" />

</LinearLayout>